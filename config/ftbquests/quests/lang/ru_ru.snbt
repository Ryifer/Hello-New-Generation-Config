	quest.0B71DD7F21BD41B8.quest_desc: [
		"Говорят, в древности гномы не знали равных в мастерстве,"
		"Кузнецы ковали несметные сокровища,"
		"Молот падал, словно колокол звенел,"
		"Звон разносился по священным чертогам Одинокой горы."
		""
		"В долине гулко завыла тревога,"
		"С севера пришло роковое пламя,"
		"Копья, как лес, но не победить смерть,"
		"Смауг залёг в сокровищах Одинокой горы."
		""
		"Возможно, стоит поискать ту самую Одинокую гору"
	]
	quest.0B71DD7F21BD41B8.quest_subtitle: "Баллада"
